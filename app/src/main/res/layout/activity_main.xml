<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <FrameLayout
        android:id="@+id/frame"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true">
        <jp.co.cyberagent.android.gpuimage.GPUImageView
            android:id="@+id/view"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />
        <View
            android:id="@+id/flash"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#888888"
            android:visibility="gone" />
    </FrameLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_above="@+id/filters"
        android:gravity="center"
        android:layout_marginBottom="30dp"
        android:orientation="horizontal">
        <Button
            android:id="@+id/flip"
            android:layout_width="60dp"
            android:layout_height="50dp"
            android:text="FLIP"
            android:layout_marginRight="40dp"
            android:background="#111111"
            android:textColor="#FFFFFF" />
        <Button
            android:id="@+id/shutter"
            android:layout_width="70dp"
            android:layout_height="70dp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/filters"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:orientation="horizontal"
        android:padding="10dp"
        android:background="#000000">
        <Button android:id="@+id/b_gb" android:layout_width="0dp" android:layout_height="50dp" android:layout_weight="1" android:layout_margin="2dp" android:background="#111111" android:text="GAMEBOY" android:textColor="#FFFFFF" />
        <Button android:id="@+id/b_pol" android:layout_width="0dp" android:layout_height="50dp" android:layout_weight="1" android:layout_margin="2dp" android:background="#111111" android:text="POLAROID" android:textColor="#FFFFFF" />
        <Button android:id="@+id/b_fuji" android:layout_width="0dp" android:layout_height="50dp" android:layout_weight="1" android:layout_margin="2dp" android:background="#111111" android:text="FUJIFILM" android:textColor="#FFFFFF" />
    </LinearLayout>
</RelativeLayout>